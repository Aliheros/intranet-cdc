# URL de l'API backend (en prod, pointer vers le domaine réel)
# Si Nginx reverse-proxy sur le même domaine : VITE_API_URL=/api
# Si API sur un sous-domaine séparé : VITE_API_URL=https://api.votredomaine.fr/api
VITE_API_URL=/api

# URL de base du serveur (pour les uploads/fichiers statiques)
# Même valeur que VITE_API_URL sans /api, ou URL complète si séparé
VITE_SERVER_URL=
