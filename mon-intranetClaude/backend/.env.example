# ── Base de données ─────────────────────────────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://UTILISATEUR:MOT_DE_PASSE@HOTE:5432/intranet_db"

# ── Secrets JWT ─────────────────────────────────────────────────────────────
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGER_AVEC_64_OCTETS_ALEATOIRES"
JWT_REFRESH_SECRET="CHANGER_AVEC_64_OCTETS_ALEATOIRES_DIFFERENT"

# ── Serveur ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL="https://intranet.votredomaine.fr"
APP_URL="https://intranet.votredomaine.fr"
# ALLOWED_ORIGINS=https://autre.domaine.fr

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=adresse@votredomaine.fr
SMTP_PASS=MOT_DE_PASSE_APPLICATION
SMTP_FROM="Intranet <adresse@votredomaine.fr>"

# ── Seed ─────────────────────────────────────────────────────────────────────
# Mot de passe temporaire attribué lors du seed initial — à changer aussitôt
SEED_PASSWORD="MotDePasseTemporaire!Change-Moi"

# ── Google Drive Export ───────────────────────────────────────────────────────
# Export automatique de toutes les données vers Google Drive via Service Account.
# Voir la documentation : docs/GOOGLE_DRIVE_SETUP.md
#
# Chemin absolu vers le fichier JSON de clé du Service Account Google.
# Ce fichier ne doit JAMAIS être commité dans le dépôt git.
# En production : /etc/secrets/google-service-account.json (ou équivalent)
# En dev : ./google-service-account.json (hors du dossier du dépôt)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/etc/secrets/google-service-account.json
#
# ID du dossier Google Drive partagé avec le Service Account (visible dans l'URL Drive)
# Ex : https://drive.google.com/drive/folders/1AbCdEfGhIjKlMnOpQrStUvWxYz
#                                                               ↑ cet ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=
#
# Expression cron du déclenchement automatique (Europe/Paris)
# Défaut : tous les jours à 07:00. Format : "min heure jour-mois mois jour-semaine"
DRIVE_EXPORT_CRON=0 7 * * *
